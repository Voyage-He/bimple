{
    "manifest_version": 3,
    "name": "bimple - Simplify Bilibili",
    "short_name": "bimple",
    "description": "Hide Bilibili recommendations, comments and other distractions for a cleaner viewing experience",
    "version": "1.0.1",
    "author": "Voyage-He",
    "homepage_url": "https://github.com/Voyage-He/bimple",
    "permissions": ["storage"],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png"
        },
        "default_popup": "popup.html",
        "default_title": "bimple Settings"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://*.bilibili.com/*"],
            "js": ["content/index.js"],
            "run_at": "document_start"
        }
    ]
}
