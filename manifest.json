{
    "manifest_version": 3,
    "name": "bimple",
    "description": "simplify",
    "version": "1.2",
    "permissions": ["storage"],
    "action": {
      "default_popup": "popup.html"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://*.bilibili.com/*"],
            "js": ["content/index.js"]
        }
    ]
}
